# PRODUCTION ENVIRONMENT CONFIGURATION
# Copy this file to .env.production and update the values

APP_NAME=Laravel
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Database Configuration
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=fitness_production
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_THIS_SECURE_PASSWORD

# Session Configuration
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

# Cache Configuration
CACHE_STORE=redis

# Queue Configuration
QUEUE_CONNECTION=redis

# Redis Configuration
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_PORT=6379

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# CORS Configuration (Update with your frontend domain)
SANCTUM_STATEFUL_DOMAINS=yourdomain.com
SANCTUM_TOKEN_DOMAIN=yourdomain.com

# Security Notes:
# 1. APP_DEBUG must be false in production
# 2. Use strong, unique passwords
# 3. Enable SSL/TLS for database connections
# 4. Set up proper CORS origins
# 5. Enable session encryption
# 6. Use Redis for cache and queue in production
# 7. Keep APP_KEY secret and rotate it periodically
